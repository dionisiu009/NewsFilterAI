# ==============================================================================
# NEWSFILTERAI - ENVIRONMENT VARIABLES
# ==============================================================================
# Скопіюй цей файл як .env і заповни реальними значеннями:
# cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# DJANGO SETTINGS
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=django-insecure-change-this-key-for-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ------------------------------------------------------------------------------
# DJANGO SUPERUSER (створюється автоматично при запуску)
# ------------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# ------------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_DB=newsfilter_db
POSTGRES_USER=newsfilter_user
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# REDIS (Broker + Cache)
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ------------------------------------------------------------------------------
# GOOGLE GEMINI AI
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# ------------------------------------------------------------------------------
# TELEGRAM BOT
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BACKEND_API_URL=http://backend:8000/api

# ------------------------------------------------------------------------------
# CORS (Frontend URL)
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# CACHE SETTINGS
# ------------------------------------------------------------------------------
# 6 hours in seconds
NEWS_CACHE_TTL=21600

# ------------------------------------------------------------------------------
# NGROK (Tunneling)
# ------------------------------------------------------------------------------
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

