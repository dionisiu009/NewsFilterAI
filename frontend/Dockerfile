# ==============================================================================
# NEWSFILTERAI - FRONTEND DOCKERFILE (React + Vite)
# ==============================================================================

FROM node:24-alpine

# Встановлюємо робочу директорію
WORKDIR /app

# Копіюємо файли залежностей
COPY package*.json ./

# Встановлюємо залежності
RUN npm install

# Копіюємо весь код
COPY . .

# Порт для Vite dev server
EXPOSE 5173

# Запускаємо dev server з доступом ззовні
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

